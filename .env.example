# EmareCloud Yapılandırma
# Bu dosyayı .env olarak kopyalayın ve değerleri düzenleyin

# Ortam
FLASK_ENV=production

# Güvenlik (MUTLAKA değiştirin!)
SECRET_KEY=your-secret-key-here-change-in-production
MASTER_KEY=your-master-encryption-key-change-in-production

# Varsayılan Admin (ilk kurulumda)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-this-password-immediately
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com

# Veritabanı (varsayılan: SQLite)
# PostgreSQL: postgresql://user:pass@host:5432/emarecloud
DATABASE_URL=

# Oturum
SESSION_LIFETIME_HOURS=8
SESSION_COOKIE_SECURE=true

# Rate Limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_WINDOW=300

# SSH
SSH_TIMEOUT=10
MAX_CONCURRENT_CONNECTIONS=5

# Sunucu
HOST=0.0.0.0
PORT=5555
