[Unit]
Description=Emare Asistan FastAPI Servisi
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/emareasistan
ExecStart=/opt/emareasistan-venv/bin/uvicorn main:app --host 127.0.0.1 --port 8201 --workers 2
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
