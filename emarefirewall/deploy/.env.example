# Emare Security OS production environment
EMARE_MODE=isp
EMARE_HOST=127.0.0.1
EMARE_PORT=8202
EMARE_WORKERS=2
EMARE_DEBUG=0
EMARE_SECRET_KEY=degistir_beni

# Backends
EMARE_CACHE=redis
EMARE_REDIS_URL=redis://127.0.0.1:6379/5
EMARE_DB=sqlite
EMARE_SQLITE_PATH=/var/www/emaresecurityos/data/emaresecurityos.db

# Security / rate limiting
EMARE_RATE_LIMIT=60
EMARE_SSH_TIMEOUT=12
EMARE_SSH_POOL_SIZE=8

# 5651
EMARE_5651_ENABLED=1
EMARE_5651_ORGANIZATION=Emare Security OS
EMARE_5651_STAMP_EVERY=1
EMARE_5651_TSA_URL=
EMARE_5651_TSA_USERNAME=
EMARE_5651_TSA_PASSWORD=
EMARE_5651_TSA_TIMEOUT=10
EMARE_5651_TSA_DRY_RUN=1
EMARE_5651_TSA_CA_FILE=
