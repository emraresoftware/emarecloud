# =====================================================================
# GitHub API Entegrasyonu — Açık Kaynak Proje Arama ve Keşif
# =====================================================================

_SSL_CTX = None

def _get_ssl_ctx():
    """SSL context oluşturur (sertifika doğrulama ile)."""
    global _SSL_CTX
    if _SSL_CTX is None:
        _SSL_CTX = ssl.create_default_context()
    return _SSL_CTX


def github_search(query: str, language: str = "", sort: str = "stars",
                  per_page: int = 30, page: int = 1) -> dict:
    """
    GitHub API üzerinden repo arama. Rate limit: 10 req/dk (unauthenticated).
    Döndürür: { total_count, items: [ { name, full_name, description, stargazers_count,
                language, html_url, owner { login, avatar_url }, topics, ... } ] }
    """
    q_parts = [query]
    if language:
        q_parts.append(f"language:{language}")
    q = " ".join(q_parts)

    params = urllib.parse.urlencode({
        "q": q,
        "sort": sort,
        "order": "desc",
        "per_page": min(per_page, 100),
        "page": page,
    })
    url = f"https://api.github.com/search/repositories?{params}"
    req = urllib.request.Request(url, headers={
        "Accept": "application/vnd.github+json",
        "User-Agent": "SunucuYonetimi-Panel/2.0",
    })
    try:
        with urllib.request.urlopen(req, timeout=15, context=_get_ssl_ctx()) as resp:
            data = json.loads(resp.read().decode("utf-8"))
            return {
                "total_count": data.get("total_count", 0),
                "items": [
                    {
                        "id": r["full_name"].replace("/", "--"),
                        "name": r["name"],
                        "full_name": r["full_name"],
                        "description": (r.get("description") or "")[:200],
                        "stars": r.get("stargazers_count", 0),
                        "language": r.get("language") or "—",
                        "url": r.get("html_url", ""),
                        "owner": r.get("owner", {}).get("login", ""),
                        "avatar": r.get("owner", {}).get("avatar_url", ""),
                        "topics": r.get("topics", [])[:5],
                        "forks": r.get("forks_count", 0),
                        "updated_at": (r.get("updated_at") or "")[:10],
                        "license": (r.get("license") or {}).get("spdx_id", ""),
                        "open_issues": r.get("open_issues_count", 0),
                        "default_branch": r.get("default_branch", "main"),
                    }
                    for r in data.get("items", [])
                ],
            }
    except Exception as e:
        return {"total_count": 0, "items": [], "error": str(e)}


def github_trending(language: str = "", since: str = "weekly") -> dict:
    """
    GitHub'da popüler repoları bul.
    since: daily, weekly, monthly.
    """
    q = "stars:>1000"
    if language:
        q += f" language:{language}"
    if since == "daily":
        q += " pushed:>2026-02-28"
    elif since == "weekly":
        q += " pushed:>2026-02-22"
    else:
        q += " pushed:>2026-02-01"
    return github_search(q, sort="stars", per_page=30)


def github_get_readme(full_name: str) -> str:
    """Bir repo'nun README.md içeriğini döndürür (ilk 2000 karakter)."""
    url = f"https://api.github.com/repos/{full_name}/readme"
    req = urllib.request.Request(url, headers={
        "Accept": "application/vnd.github.raw+json",
        "User-Agent": "SunucuYonetimi-Panel/2.0",
    })
    try:
        with urllib.request.urlopen(req, timeout=10, context=_get_ssl_ctx()) as resp:
            text = resp.read().decode("utf-8", errors="replace")
            return text[:3000]
    except Exception:
        return ""


def github_install_script(full_name: str, branch: str = "main") -> str:
    """
    Bir GitHub projesini sunucuya klonlayıp kurmak için generic script üretir.
    Eğer repo'da install.sh, setup.sh, docker-compose.yml veya Makefile varsa onları kullanır.
    """
    safe_name = full_name.replace("/", "_").replace(" ", "_")
    return f"""set -e
export DEBIAN_FRONTEND=noninteractive 2>/dev/null || true

# Gerekli araçlar
command -v git >/dev/null 2>&1 || {{ apt-get update -qq && apt-get install -y -qq git; }} 2>/dev/null || true

echo "📥 {full_name} klonlanıyor..."
mkdir -p /opt/github-apps
cd /opt/github-apps
rm -rf {safe_name} 2>/dev/null || true
git clone --depth 1 -b {branch} https://github.com/{full_name}.git {safe_name}
cd {safe_name}

echo "🔍 Kurulum yöntemi aranıyor..."

# 1) Docker Compose
if [ -f docker-compose.yml ] || [ -f docker-compose.yaml ] || [ -f compose.yml ]; then
    echo "🐳 Docker Compose bulundu, başlatılıyor..."
    command -v docker >/dev/null 2>&1 || {{ echo "Docker gerekli. Önce Docker kurun."; exit 1; }}
    docker compose up -d 2>/dev/null || docker-compose up -d 2>/dev/null || true
    echo "✅ {full_name} Docker Compose ile başlatıldı."
    exit 0
fi

# 2) Dockerfile
if [ -f Dockerfile ]; then
    echo "🐳 Dockerfile bulundu, image oluşturuluyor..."
    command -v docker >/dev/null 2>&1 || {{ echo "Docker gerekli. Önce Docker kurun."; exit 1; }}
    docker build -t {safe_name} . 2>/dev/null || true
    docker run -d --name {safe_name} --restart unless-stopped {safe_name} 2>/dev/null || true
    echo "✅ {full_name} Docker ile başlatıldı."
    exit 0
fi

# 3) Makefile
if [ -f Makefile ]; then
    echo "⚙️ Makefile bulundu..."
    apt-get install -y -qq build-essential 2>/dev/null || true
    make install 2>/dev/null || make 2>/dev/null || true
    echo "✅ {full_name} make ile kuruldu."
    exit 0
fi

# 4) install.sh / setup.sh
for script in install.sh setup.sh start.sh; do
    if [ -f "$script" ]; then
        echo "📜 $script bulundu, çalıştırılıyor..."
        chmod +x "$script"
        ./"$script" 2>/dev/null || true
        echo "✅ {full_name} $script ile kuruldu."
        exit 0
    fi
done

# 5) Python projesi
if [ -f requirements.txt ]; then
    echo "🐍 Python projesi algılandı..."
    apt-get install -y -qq python3 python3-pip python3-venv 2>/dev/null || true
    python3 -m venv venv
    ./venv/bin/pip install -r requirements.txt 2>/dev/null || true
    echo "✅ {full_name} kuruldu. cd /opt/github-apps/{safe_name} && source venv/bin/activate"
    exit 0
fi

if [ -f setup.py ] || [ -f pyproject.toml ]; then
    echo "🐍 Python paketi algılandı..."
    apt-get install -y -qq python3 python3-pip 2>/dev/null || true
    pip3 install . 2>/dev/null || pip3 install --break-system-packages . 2>/dev/null || true
    echo "✅ {full_name} pip ile kuruldu."
    exit 0
fi

# 6) Node.js projesi
if [ -f package.json ]; then
    echo "📦 Node.js projesi algılandı..."
    command -v node >/dev/null 2>&1 || {{ curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && apt-get install -y -qq nodejs; }} 2>/dev/null || true
    npm install 2>/dev/null || true
    echo "✅ {full_name} kuruldu. cd /opt/github-apps/{safe_name} && npm start"
    exit 0
fi

# 7) Go projesi
if [ -f go.mod ]; then
    echo "🔷 Go projesi algılandı..."
    command -v go >/dev/null 2>&1 || {{ apt-get install -y -qq golang 2>/dev/null || true; }}
    go build ./... 2>/dev/null || true
    echo "✅ {full_name} derlendi."
    exit 0
fi

# 8) Rust projesi
if [ -f Cargo.toml ]; then
    echo "🦀 Rust projesi algılandı..."
    command -v cargo >/dev/null 2>&1 || {{ curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y; source $HOME/.cargo/env; }}
    cargo build --release 2>/dev/null || true
    echo "✅ {full_name} derlendi."
    exit 0
fi

echo "✅ {full_name} /opt/github-apps/{safe_name} konumuna klonlandı."
echo "📂 Lütfen projenin README.md dosyasını okuyarak kurulum talimatlarını takip edin."
"""


# =====================================================================
# Mevcut API fonksiyonları (app.py uyumluluğu)
# =====================================================================

def get_app(app_id: str) -> dict | None:
    """Uygulama tanımını döndürür."""
    return MARKET_APPS.get(app_id)


def get_all_apps() -> list:
    """Tüm uygulamaları liste olarak döndürür."""
    return list(MARKET_APPS.values())


def get_categories() -> list:
    """Benzersiz kategori listesi."""
    return sorted({app["category"] for app in MARKET_APPS.values()})


# Kategori ikonları ve renkleri
CATEGORY_META = {
    "Veritabanı":          {"icon": "fa-database",        "color": "#4c8dff"},
    "Web Sunucu":          {"icon": "fa-globe",           "color": "#00c9a7"},
    "Konteyner & Altyapı": {"icon": "fa-cubes",           "color": "#7c5cfc"},
    "İzleme & Gözlem":     {"icon": "fa-chart-area",      "color": "#ff6b6b"},
    "Güvenlik":            {"icon": "fa-shield-alt",      "color": "#ffa726"},
    "Geliştirme":          {"icon": "fa-code",            "color": "#26c6da"},
    "Web Uygulamalar":     {"icon": "fa-window-maximize", "color": "#ec407a"},
    "AI / Yapay Zeka":     {"icon": "fa-brain",           "color": "#ab47bc"},
    "İletişim":            {"icon": "fa-comments",        "color": "#42a5f5"},
    "Medya":               {"icon": "fa-photo-video",     "color": "#ef5350"},
    "Yedekleme":           {"icon": "fa-hdd",             "color": "#8d6e63"},
}

# Kategori sıralaması (UI'da gösterim sırası)
CATEGORY_ORDER = [
    "Veritabanı", "Web Sunucu", "Konteyner & Altyapı",
    "İzleme & Gözlem", "Güvenlik", "Geliştirme",
    "Web Uygulamalar", "AI / Yapay Zeka", "İletişim",
    "Medya", "Yedekleme",
]


def get_category_meta() -> dict:
    """Kategori meta bilgilerini döndürür (ikon, renk)."""
    return CATEGORY_META


def get_apps_by_category() -> list:
    """Uygulamaları kategorilere göre gruplanmış olarak döndürür.
    Döndürülen yapı: [{"name": "...", "icon": "...", "color": "...", "apps": [...]}]
    """
    from collections import OrderedDict
    grouped = OrderedDict()
    # Önce sıralı kategorileri oluştur
    for cat in CATEGORY_ORDER:
        if cat not in grouped:
            grouped[cat] = []
    # Uygulamaları ekle
    for app in MARKET_APPS.values():
        cat = app.get("category", "Diğer")
        if cat not in grouped:
            grouped[cat] = []
        grouped[cat].append(app)
    # Sonuç listesi
    result = []
    for cat_name, apps in grouped.items():
        if not apps:
            continue
        meta = CATEGORY_META.get(cat_name, {"icon": "fa-folder", "color": "#888"})
        result.append({
            "name": cat_name,
            "icon": meta["icon"],
            "color": meta["color"],
            "count": len(apps),
            "apps": apps,
        })
    return result


def build_install_script(app_id: str, options: dict) -> str:
    """Kullanıcı seçenekleriyle kurulum scriptini oluşturur."""
    app = get_app(app_id)
    if not app:
        return ""
    script = app.get("install_script", "")
    for key, value in (options or {}).items():
        script = script.replace("{{" + key + "}}", str(value).replace("'", "'\\''"))
    return script
